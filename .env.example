# Copy this file to .env and fill in your values
# Never commit .env to git

ANTHROPIC_API_KEY=sk-ant-api03-...

# Twilio — from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio WhatsApp sender number (Sandbox: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Owner's real WhatsApp number to receive lead notifications
OWNER_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX

# Optional: path to a custom business.json for this client
# BUSINESS_CONFIG_PATH=/path/to/client_business.json

# Port (Railway/Render set this automatically)
PORT=5000

